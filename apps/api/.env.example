# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/budgify_dev
DATABASE_ECHO=false

# Application
APP_ENV=development
APP_NAME=Budgify
LOG_LEVEL=INFO
API_PREFIX=/api

# Security (placeholders for Phase 2+)
PLATFORM_ADMIN_KEY=change-me
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
